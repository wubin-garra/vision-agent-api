# 文本推理
LLM_PROVIDER=deepseek
DEEPSEEK_API_KEY=
DEEPSEEK_LLM_MODEL=deepseek-v4-pro
DEEPSEEK_ROUTER_MODEL=deepseek-v4-flash

# 图片理解（推荐 OpenAI gpt-4o-mini，支持直接传图）
VISION_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_VISION_MODEL=gpt-4o-mini

# 或使用 DashScope Qwen-VL
# VISION_PROVIDER=dashscope
# DASHSCOPE_API_KEY=
# DASHSCOPE_VISION_MODEL=qwen-vl-max

DATABASE_PATH=./vision_agent.db
UPLOAD_DIR=./uploads
PORT=8000
DEBUG=true
